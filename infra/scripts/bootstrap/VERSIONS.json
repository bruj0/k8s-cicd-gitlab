{
  "tools": {
    "docker": {
      "version": ">=24.0",
      "package_by_family": { "arch": "docker", "debian": "docker.io", "rhel": "docker", "darwin": "--cask docker" }
    },
    "kubectl": {
      "version": ">=1.31.0",
      "package_by_family": { "arch": "kubectl", "debian": "kubectl", "rhel": "kubectl", "darwin": "kubernetes-cli" }
    },
    "kind": {
      "version": "v0.27.0",
      "binary_url_linux_amd64": "https://kind.sigs.k8s.io/dl/v0.27.0/kind-linux-amd64",
      "package_by_family": { "arch": "kind", "debian": "kind", "rhel": "kind", "darwin": "kind" }
    },
    "helm": {
      "version": ">=3.16.0",
      "package_by_family": { "arch": "helm", "debian": "helm", "rhel": "helm", "darwin": "helm" }
    },
    "opentofu": {
      "version": ">=1.6",
      "package_by_family": { "arch": "opentofu", "debian": "opentofu", "rhel": "opentofu", "darwin": "opentofu" }
    },
    "openssl": {
      "version": ">=3.0",
      "package_by_family": { "arch": "openssl", "debian": "openssl", "rhel": "openssl", "darwin": "openssl@3" }
    }
  },
  "kubernetes": {
    "kindest_node_image": "kindest/node:v1.31.0"
  },
  "helm_repositories": {
    "local-path-provisioner": {
      "name": "local-path-provisioner",
      "source": "https://raw.githubusercontent.com/rancher/local-path-provisioner/v0.0.30/deploy/local-path-storage.yaml",
      "version": "v0.0.30",
      "kind": "kubectl-apply",
      "comment": "Upstream applies directly via `kubectl apply -f <url>` (no helm chart). Version is pinned to the raw-manifest tag so a bump is one edit here."
    },
    "headlamp": {
      "name": "headlamp",
      "url": "https://kubernetes-sigs.github.io/headlamp/",
      "chart": "headlamp",
      "chart_version": "0.43.0",
      "values_overrides": {
        "service": { "type": "NodePort" }
      }
    },
    "openbao": {
      "name": "openbao",
      "url": "https://openbao.github.io/openbao-helm",
      "chart": "openbao",
      "chart_version": "0.10.1",
      "values_overrides": {
        "server": {
          "ha": { "enabled": false, "replicas": 1 },
          "audit": { "enabled": false },
          "ui": { "enabled": true }
        }
      }
    },
    "gitlab": {
      "name": "gitlab",
      "url": "https://charts.gitlab.io",
      "chart": "gitlab",
      "chart_version": "10.1.1",
      "values_overrides": {
        "global": {
          "edition": "ce",
          "hosts": {
            "domain": "local.bruj0.net",
            "externalIP": "127.0.0.1",
            "https": true
          },
          "ingress": { "enabled": false },
          "gatewayApi": {
            "enabled": true,
            "installEnvoy": true,
            "configureCertmanager": false,
            "httpToHttpsRedirect": true
          },
          "storageClass": "local-path"
        },
        "certmanager-issuer": {
          "email": "[email protected]"
        }
      }
    },
    "gitlab-runner": {
      "name": "gitlab-runner",
      "url": "https://charts.gitlab.io",
      "chart": "gitlab-runner",
      "chart_version": "0.71.0",
      "values_overrides": {
        "gitlabUrl": "http://gitlab-webservice-default.gitlab.svc:8181",
        "runners": {
          "executor": "kubernetes",
          "kubernetes": {
            "namespace": "gitlab-runner"
          }
        }
      }
    },
    "cloudnative-pg": {
      "name": "cloudnative-pg",
      "url": "https://cloudnative-pg.github.io/charts",
      "chart": "cloudnative-pg",
      "chart_version": "0.29.0",
      "comment": "Operator for CloudNativePG. Installed once per cluster; manages Cluster/postgresql CRDs that GitLab chart 10.x (and chart-managed OpenBao v0.15.1) consume as external PostgreSQL."
    },
    "redis": {
      "name": "redis",
      "url": "https://charts.bitnami.com/bitnami",
      "chart": "redis",
      "chart_version": "27.0.13",
      "comment": "Single-node Redis (master only, no replicas) for chart 10.x external Redis. The chart auto-generates a `redis-password` Secret which we then reference from `global.redis.auth.secret`."
    },
    "minio": {
      "name": "minio",
      "url": "https://charts.min.io/",
      "chart": "minio",
      "chart_version": "5.4.0",
      "comment": "Standalone (single-node) MinIO for chart 10.x external object storage. GitLab chart creates ObjectBucketClaims against this MinIO for lfs/artifacts/uploads/packages/etc."
    }
  }
}