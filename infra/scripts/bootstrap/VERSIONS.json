{
  "tools": {
    "docker": {
      "version": ">=24.0",
      "package_by_family": { "arch": "docker", "debian": "docker.io", "rhel": "docker", "darwin": "--cask docker" }
    },
    "kubectl": {
      "version": ">=1.31.0",
      "package_by_family": { "arch": "kubectl", "debian": "kubectl", "rhel": "kubectl", "darwin": "kubernetes-cli" }
    },
    "kind": {
      "version": "v0.27.0",
      "binary_url_linux_amd64": "https://kind.sigs.k8s.io/dl/v0.27.0/kind-linux-amd64",
      "package_by_family": { "arch": "kind", "debian": "kind", "rhel": "kind", "darwin": "kind" }
    },
    "helm": {
      "version": ">=3.16.0",
      "package_by_family": { "arch": "helm", "debian": "helm", "rhel": "helm", "darwin": "helm" }
    },
    "opentofu": {
      "version": ">=1.6",
      "package_by_family": { "arch": "opentofu", "debian": "opentofu", "rhel": "opentofu", "darwin": "opentofu" }
    },
    "openssl": {
      "version": ">=3.0",
      "package_by_family": { "arch": "openssl", "debian": "openssl", "rhel": "openssl", "darwin": "openssl@3" }
    }
  },
  "kubernetes": {
    "kindest_node_image": "kindest/node:v1.31.0"
  },
  "helm_repositories": {
    "headlamp": {
      "name": "headlamp",
      "url": "https://kubernetes-sigs.github.io/headlamp/",
      "chart": "headlamp",
      "chart_version": "0.43.0",
      "values_overrides": {
        "service": { "type": "NodePort" }
      }
    },
    "traefik": {
      "name": "traefik",
      "url": "https://traefik.github.io/charts",
      "chart": "traefik",
      "chart_version": "36.4.0",
      "values_overrides": {
        "ports": {
          "web": { "redirectTo": "websecure" }
        },
        "providers": {
          "kubernetesGateway": { "enabled": true }
        },
        "ingressClass": {
          "enabled": false
        }
      }
    },
    "openbao": {
      "name": "openbao",
      "url": "https://openbao.github.io/openbao-helm",
      "chart": "openbao",
      "chart_version": "0.10.1",
      "values_overrides": {
        "server": {
          "ha": { "enabled": false, "replicas": 1 },
          "audit": { "enabled": false },
          "ui": { "enabled": true }
        }
      }
    },
    "gitlab": {
      "name": "gitlab",
      "url": "https://gitlab.gitlab.io/charts",
      "chart": "gitlab",
      "chart_version": "8.10.0",
      "values_overrides": {
        "global": {
          "edition": "ce",
          "hosts": {
            "domain": "local.bruj0.net",
            "externalIP": "127.0.0.1",
            "https": true
          },
          "ingress": { "enabled": false },
          "gateway": { "enabled": false },
          "appConfig": {
            "secretBackend": {
              "type": "kubernetes",
              "kubernetes": { "secretName": "gitlab-secret-backend" }
            }
          }
        }
      }
    },
    "gitlab-runner": {
      "name": "gitlab-runner",
      "url": "https://charts.gitlab.io",
      "chart": "gitlab-runner",
      "chart_version": "0.71.0",
      "values_overrides": {
        "gitlabUrl": "https://gitlab.local.bruj0.net",
        "runners": {
          "executor": "kubernetes",
          "kubernetes": {
            "namespace": "gitlab-runner"
          }
        }
      }
    }
  }
}