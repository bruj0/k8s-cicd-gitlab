# Copy to tofu.tfvars and edit. Real tfvars are gitignored.
cluster_name        = "cicd"
kubernetes_version  = "v1.31.0"
domain              = "local.bruj0.net"
kubeconfig_path     = "./kubeconfig"
data_root           = "../data"

