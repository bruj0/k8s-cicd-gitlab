# Local dev environment overrides. Real .env is gitignored.
#
# This file documents the keys you might want to set in your own
# .env. They are loaded by shell scripts in the bootstrap pipeline
# (see infra/scripts/bootstrap/app.py for the load order).
#
# Example: the Headlamp dashboard returns a short-lived JWT on
# `kubectl create token headlamp -n headlamp`. Stash it here so
# subsequent shell invocations can paste it into the dashboard
# without re-running kubectl.

HEADLAMP=
