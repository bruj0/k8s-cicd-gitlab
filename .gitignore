# PKI scratch dir: never commit anything under infra/tls/.
#   private/ — Phase 1 PKI helper output (deleted; kept as a path
#              so old checkouts don't choke on the dir).
#   public/  — one-shot export target for the GitLab chart's cfssl
#              Job (kubectl get secret … | base64 -d > ca.crt, then
#              `sudo trust anchor ca.crt`). Re-export after every
#              re-install; CAs are not stable across regenerations.
infra/tls/*
!infra/tls/.gitkeep

# OpenTofu working files
infra/tofu/.terraform/
infra/tofu/.terraform.lock.hcl
infra/tofu/terraform.tfstate
infra/tofu/terraform.tfstate.backup
# Local override of variables (use .example as the committed template)
infra/tofu/*.tfvars
!infra/tofu/*.tfvars.example
# Smoke-test snapshot written by null_resource
infra/tofu/.last_smoke.json
# Generated kubeconfig (contains client cert + key base64-encoded inside)
infra/tofu/kubeconfig

# Phase 2 runtime secrets (OpenBao unseal key, GitLab init password, runner
# registration token). The dir is created by `bootstrap.py --phase 2` with
# mode 0700. NEVER commit these files.
infra/secrets/

# Persistent volume backing for chart-managed PVCs. Each GitLab subchart
# (postgres, gitaly, redis, minio, registry, sidekiq, kas, prometheus, …)
# creates a host directory under infra/data/shared/<pvc-name>-<uid>/ when
# `blueprint-bootstrap --phase 2` runs. The whole tree is owned by the
# current user after `tofu apply` (one-time sudo chown — see
# docs/phase-1.md). The data survives `tofu destroy && tofu apply` by
# design; commiting it would bloat the repo and leak auth state.
infra/data/

# Environment files (typically hold tokens, secrets, hostnames)
.env
.env.*
!.env.example

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
.mypy_cache/
.pytest_cache/

# uv: virtualenv is per-checkout and rebuildable from uv.lock + pyproject.toml
.venv/

# Editor / OS scratch
.vscode/
.idea/
.DS_Store
*.swp
*~

# kubectl client cache (~/.kube equivalent on the host)
.kube/

# Extracted chart directories (charts are kept as *.tgz in
# infra/helm-charts/; the extracted trees are working copies of
# helm_cache.py / gateway.py / etc.)
infra/helm-charts/*/